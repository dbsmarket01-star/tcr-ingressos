generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AdminRole {
  OWNER
  MANAGER
  FINANCE
  SUPPORT
  STAFF
  CHECKIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  FINISHED
  CANCELED
}

enum LotStatus {
  DRAFT
  ACTIVE
  PAUSED
  SOLD_OUT
  CLOSED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELED
  EXPIRED
  REFUNDED
}

enum PaymentProvider {
  SIMULATED
  MERCADO_PAGO
  ASAAS
  PAGARME
  STRIPE
}

enum PaymentStatus {
  CREATED
  PENDING
  APPROVED
  FAILED
  CANCELED
  REFUNDED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELED
  INVALID
}

enum CheckInStatus {
  APPROVED
  ALREADY_USED
  INVALID
  CANCELED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

enum SplitRuleType {
  PERCENTAGE
  FIXED_PER_ORDER
  FIXED_PER_TICKET
}

enum SubscriptionInterval {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
  FAMILY
}

enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AppUserStatus {
  TRIAL
  ACTIVE
  GRACE
  PAST_DUE
  CANCELED
  BLOCKED
}

enum MobilePlatform {
  ANDROID
  IOS
  WINDOWS
  MACOS
}

enum DeviceStatus {
  PENDING
  ACTIVE
  BLOCKED
  REMOVED
}

enum ProtectionMode {
  DNS_ONLY
  LOCAL_VPN
  DNS_PLUS_VPN
  APPLE_DNS_PROXY
}

enum ProtectionStatus {
  ONLINE
  DEGRADED
  OFFLINE
  LOCKED
}

enum ProtectionEventType {
  BLOCKED_DOMAIN
  BLOCKED_URL
  BLOCKED_KEYWORD
  VPN_DISABLED
  VPN_PERMISSION_REVOKED
  DNS_TAMPERING
  EXTERNAL_VPN_DETECTED
  PROXY_DETECTED
  APP_STOPPED
  UNINSTALL_ATTEMPT
  DEVICE_LIMIT_REACHED
  SUBSCRIPTION_BLOCK
  HEARTBEAT
}

enum BypassSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PENDING_PAYMENT
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentGateway {
  ASAAS
}

enum BlocklistEntryType {
  DOMAIN
  SUBDOMAIN
  URL_KEYWORD
  HOST_KEYWORD
}

enum DeviceRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UnlockRequestStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
  CANCELED
}

enum UnlockActionType {
  DISABLE_PROTECTION
  REMOVE_DEVICE
  REQUEST_UNINSTALL
  RESET_PIN
  LOGOUT_DEVICE
}

model Organization {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  publicDomain   String?
  adminDomain    String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  supportEmail   String?
  supportPhone   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  adminUsers        AdminUser[]
  companySettings   CompanySettings[]
  events            Event[]
  paymentSplitRules PaymentSplitRule[]

  @@index([isActive])
}

model AdminUser {
  id           String    @id @default(cuid())
  organizationId String?
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true)
  accessAllEvents Boolean @default(true)
  allowedEventIds String[] @default([])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdEvents Event[]
  checkIns      CheckIn[]
  passwordResetTokens AdminPasswordResetToken[]
  auditLogs AdminAuditLog[]

  @@index([organizationId])
  @@index([role])
  @@index([isActive])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model AdminPasswordResetToken {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, expiresAt])
}

model CompanySettings {
  id              String   @id @default(cuid())
  organizationId  String?
  companyName     String
  tradeName       String
  document        String
  supportEmail    String
  supportPhone    String?
  instagramUrl    String?
  facebookUrl     String?
  youtubeUrl      String?
  whatsappUrl     String?
  defaultCurrency String   @default("BRL")
  platformFeeBps  Int      @default(1000)
  orderReservationMinutes Int @default(120)
  cardPendingReservationMinutes Int @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@unique([organizationId])
}

model PaymentSplitRule {
  id           String        @id @default(cuid())
  organizationId String?
  name         String
  walletId     String
  type         SplitRuleType
  percentageBps Int?
  fixedValueInCents Int?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([isActive, sortOrder])
}

model Event {
  id                  String      @id @default(cuid())
  organizationId      String?
  slug                String      @unique
  title               String
  subtitle            String?
  description         String
  bannerUrl           String?
  bannerPosition      String      @default("center center")
  bannerCrop          String?
  eventMapImageUrl    String?
  eventMapCrop        String?
  eventMapTemplate    String      @default("AUTO")
  eventMapNotes       String?
  startsAt            DateTime
  endsAt              DateTime?
  venueName           String
  venueAddress        String
  city                String
  state               String
  status              EventStatus @default(DRAFT)
  salesStartsAt       DateTime?
  salesEndsAt         DateTime?
  importantInfo       String?
  metaPixelId         String?
  metaConversionsApiToken String?
  metaTestEventCode   String?
  googleTagManagerId  String?
  seoTitle            String?
  seoDescription      String?
  seoKeywords         String?
  seoImageUrl         String?
  supportWhatsappUrl  String?
  leadCaptureEnabled  Boolean     @default(false)
  leadCaptureHeadline String?
  leadCaptureDescription String?
  leadCaptureOfferText String?
  leadCaptureCtaText  String?
  leadCaptureHeroImageUrl String?
  leadCaptureHeroCrop String?
  leadCaptureVenueGallery String?
  leadCaptureVideoUrl String?
  leadCaptureWhatsappGroupUrl String?
  leadCaptureThankYouTitle String?
  leadCaptureThankYouDescription String?
  leadCaptureThankYouButtonText String?
  autoLeadCaptureEmailEnabled Boolean @default(true)
  autoPurchaseApprovedEmailEnabled Boolean @default(true)
  autoPendingPaymentEmailEnabled Boolean @default(true)
  conversionSocialProofText String?
  conversionUrgencyText     String?
  conversionCtaText         String?
  highlightedLotId          String?
  createdById         String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy AdminUser? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lots      TicketLot[]
  orders    Order[]
  tickets   Ticket[]
  checkIns  CheckIn[]
  coupons   Coupon[]
  presaleChecks EventPresaleCheck[]
  leads     EventLead[]
  leadCaptureAttempts LeadCaptureAttempt[]
  leadEmailCampaigns LeadEmailCampaign[]

  @@index([organizationId])
  @@index([status, startsAt])
  @@index([city, state])
}

model EventLead {
  id         String   @id @default(cuid())
  eventId     String
  name       String
  email      String
  phone      String?
  municipality String?
  thankYouViewedAt DateTime?
  whatsappClickedAt DateTime?
  whatsappClickCount Int @default(0)
  utmSource  String?
  utmMedium  String?
  utmCampaign String?
  utmContent String?
  utmTerm    String?
  referrer   String?
  landingPage String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  emailCampaignClicks LeadEmailCampaignClick[]

  @@index([eventId, createdAt])
  @@index([email])
  @@unique([eventId, email])
}

model LeadEmailCampaign {
  id             String   @id @default(cuid())
  eventId        String
  subject        String
  body           String
  imageUrl       String?
  ctaLabel       String?
  destinationUrl String
  sentCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event  Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  clicks LeadEmailCampaignClick[]

  @@index([eventId, createdAt])
}

model LeadEmailCampaignClick {
  id         String   @id @default(cuid())
  campaignId String
  leadId     String
  createdAt  DateTime @default(now())

  campaign LeadEmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     EventLead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId, createdAt])
  @@index([leadId])
}

model LeadCaptureAttempt {
  id        String   @id @default(cuid())
  eventId   String
  ipHash    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, ipHash, createdAt])
  @@index([createdAt])
}

model PlatformLead {
  id                String   @id @default(cuid())
  name              String
  email             String
  phone             String
  annualRevenueBand String
  instagramHandle   String?
  eventNiche        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
  @@unique([email])
}

model EventPresaleCheck {
  id          String   @id @default(cuid())
  eventId     String
  key         String
  label       String
  description String
  checked     Boolean  @default(false)
  note        String?
  checkedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, key])
  @@index([eventId, checked])
}

model TicketLot {
  id               String    @id @default(cuid())
  eventId          String
  name             String
  description      String?
  priceInCents     Int
  serviceFeeBps    Int       @default(0)
  pixDiscountPercentBps Int  @default(0)
  pixDiscountFixedInCents Int @default(0)
  cardInterestBpsPerInstallment Int @default(0)
  cardInterestStartsAtInstallment Int @default(2)
  totalQuantity    Int
  reservedQuantity Int       @default(0)
  soldQuantity     Int       @default(0)
  minPerOrder      Int       @default(1)
  maxPerOrder      Int       @default(10)
  salesStartsAt    DateTime?
  salesEndsAt      DateTime?
  sortOrder        Int       @default(0)
  status           LotStatus @default(DRAFT)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  tickets    Ticket[]

  @@index([eventId, status, sortOrder])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String
  document  String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  participants Participant[]

  @@index([email])
  @@index([document])
}

model Participant {
  id         String   @id @default(cuid())
  customerId String?
  name       String
  email      String?
  document   String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tickets  Ticket[]

  @@index([email])
  @@index([document])
}

model Order {
  id              String      @id @default(cuid())
  code            String      @unique
  eventId         String
  customerId      String
  couponId        String?
  couponCode      String?
  status          OrderStatus @default(PENDING_PAYMENT)
  subtotalInCents Int
  serviceFeeInCents Int      @default(0)
  pixDiscountInCents Int     @default(0)
  cardInterestInCents Int    @default(0)
  discountInCents Int         @default(0)
  totalInCents    Int
  currency        String      @default("BRL")
  expiresAt       DateTime?
  expiredEmailSentAt DateTime?
  ticketsEmailSentAt DateTime?
  paidAt          DateTime?
  canceledAt      DateTime?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  referrer        String?
  landingPage     String?
  metaFbp         String?
  metaFbc         String?
  clientIpAddress String?
  clientUserAgent String?
  metaPurchaseTrackedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  event    Event       @relation(fields: [eventId], references: [id], onDelete: Restrict)
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  coupon   Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payment  Payment?
  tickets  Ticket[]

  @@index([eventId, status, createdAt])
  @@index([status, expiresAt])
  @@index([createdAt])
  @@index([customerId])
  @@index([couponId])
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  lotId            String
  quantity         Int
  unitPriceInCents Int
  serviceFeeBps    Int      @default(0)
  serviceFeeInCents Int     @default(0)
  cardInterestBpsPerInstallment Int @default(0)
  cardInterestStartsAtInstallment Int @default(2)
  totalInCents     Int
  createdAt        DateTime @default(now())

  order   Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lot     TicketLot  @relation(fields: [lotId], references: [id], onDelete: Restrict)
  tickets Ticket[]

  @@index([orderId])
  @@index([lotId])
}

model Payment {
  id              String          @id @default(cuid())
  orderId         String          @unique
  provider        PaymentProvider @default(SIMULATED)
  status          PaymentStatus   @default(CREATED)
  externalId      String?
  checkoutUrl     String?
  pixQrCodeImage  String?
  pixQrCodePayload String?
  pixExpiresAt    DateTime?
  amountInCents   Int
  paidAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  rawPayload      Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([provider, externalId])
  @@index([externalId])
  @@index([status])
  @@index([status, updatedAt])
}

model Ticket {
  id            String       @id @default(cuid())
  code          String       @unique
  qrCodeToken   String       @unique
  orderId       String
  orderItemId   String
  eventId       String
  lotId         String
  participantId String?
  status        TicketStatus @default(ACTIVE)
  issuedAt      DateTime     @default(now())
  usedAt        DateTime?
  canceledAt    DateTime?

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  lot         TicketLot    @relation(fields: [lotId], references: [id], onDelete: Restrict)
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  checkIns    CheckIn[]

  @@index([eventId, status])
  @@index([orderId])
  @@index([lotId])
}

model CheckIn {
  id          String        @id @default(cuid())
  ticketId    String
  eventId     String
  adminUserId String?
  status      CheckInStatus
  reason      String?
  deviceName  String?
  checkedAt   DateTime      @default(now())

  ticket    Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Restrict)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([eventId, checkedAt])
  @@index([ticketId])
}

model Coupon {
  id              String       @id @default(cuid())
  eventId         String
  code            String
  type            CouponType
  status          CouponStatus @default(ACTIVE)
  percentage      Int?
  amountInCents   Int?
  maxRedemptions  Int?
  redeemedCount   Int          @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([eventId, code])
  @@index([eventId, status])
}

model SubscriptionPlan {
  id                    String               @id @default(cuid())
  code                  String               @unique
  name                  String
  description           String?
  status                PlanStatus           @default(DRAFT)
  interval              SubscriptionInterval
  durationDays          Int
  priceInCents          Int
  trialDays             Int                  @default(7)
  gracePeriodDays       Int                  @default(2)
  maxDevices            Int
  allowsAccountability  Boolean              @default(false)
  allowsEmergencyMode   Boolean              @default(true)
  allowsRecoveryTools   Boolean              @default(true)
  sortOrder             Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  subscriptions Subscription[]

  @@index([status, sortOrder])
}

model AppUser {
  id                       String          @id @default(cuid())
  name                     String
  email                    String          @unique
  passwordHash             String?
  status                   AppUserStatus   @default(TRIAL)
  trialEndsAt              DateTime?
  accessEndsAt             DateTime?
  accountabilityEmail      String?
  recoveryStartDate        DateTime?
  currentStreakDays        Int             @default(0)
  longestStreakDays        Int             @default(0)
  emergencyModeEnabled     Boolean         @default(false)
  emergencyModeUntil       DateTime?
  mustStayProtected        Boolean         @default(true)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  subscriptions            Subscription[]
  devices                  ProtectedDevice[]
  protectionEvents         ProtectionEvent[]
  bypassIncidents          BypassIncident[]
  sessions                 AppUserSession[]
  unlockRequests           UnlockRequest[]
  accountabilityRelations  AccountabilityLink[] @relation("UserAccountability")
  guardianRelations        AccountabilityLink[] @relation("GuardianAccountability")

  @@index([status, accessEndsAt])
}

model AppUserSession {
  id            String   @id @default(cuid())
  userId        String
  tokenHash     String   @unique
  deviceLabel   String?
  expiresAt     DateTime
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  planId                 String
  status                 SubscriptionStatus @default(TRIALING)
  gateway                PaymentGateway     @default(ASAAS)
  asaasCustomerId        String?
  asaasSubscriptionId    String?            @unique
  asaasPaymentId         String?
  externalReference      String?            @unique
  startedAt              DateTime           @default(now())
  trialEndsAt            DateTime?
  currentPeriodStartsAt  DateTime?
  currentPeriodEndsAt    DateTime?
  graceEndsAt            DateTime?
  canceledAt             DateTime?
  lastPaymentAt          DateTime?
  nextBillingAt          DateTime?
  metadata               Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  paymentEvents SubscriptionPaymentEvent[]

  @@index([userId, status])
  @@index([planId, status])
}

model SubscriptionPaymentEvent {
  id                   String             @id @default(cuid())
  subscriptionId       String
  gateway              PaymentGateway     @default(ASAAS)
  gatewayEventId       String?
  gatewayPaymentId     String?
  gatewayStatus        String
  amountInCents        Int?
  paidAt               DateTime?
  dueDate              DateTime?
  rawPayload           Json?
  createdAt            DateTime           @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([gatewayPaymentId])
}

model ProtectedDevice {
  id                       String            @id @default(cuid())
  userId                   String
  nickname                 String?
  platform                 MobilePlatform
  status                   DeviceStatus      @default(PENDING)
  protectionMode           ProtectionMode
  protectionStatus         ProtectionStatus  @default(OFFLINE)
  deviceFingerprint        String            @unique
  installationKey          String            @unique
  pushToken                String?
  appVersion               String?
  osVersion                String?
  lastHeartbeatAt          DateTime?
  vpnEnabled               Boolean           @default(false)
  dnsProfileInstalled      Boolean           @default(false)
  externalVpnDetected      Boolean           @default(false)
  developerModeDetected    Boolean           @default(false)
  uninstallGuardEnabled    Boolean           @default(false)
  protectedByPin           Boolean           @default(false)
  riskLevel                DeviceRiskLevel   @default(LOW)
  riskUpdatedAt            DateTime?
  protectionLockedAt       DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  protectionEvents ProtectionEvent[]
  bypassIncidents BypassIncident[]
  unlockRequests UnlockRequest[]

  @@index([userId, status])
  @@index([platform, protectionStatus])
  @@index([lastHeartbeatAt])
}

model ProtectionEvent {
  id                 String              @id @default(cuid())
  userId             String
  deviceId           String?
  type               ProtectionEventType
  severity           BypassSeverity      @default(LOW)
  blockedValue       String?
  matchedRule        String?
  metadata           Json?
  createdAt          DateTime            @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  device ProtectedDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([deviceId, createdAt])
  @@index([type, createdAt])
}

model BypassIncident {
  id                 String            @id @default(cuid())
  userId             String
  deviceId           String?
  severity           BypassSeverity
  title              String
  description        String
  resolvedAt         DateTime?
  metadata           Json?
  createdAt          DateTime          @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  device ProtectedDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, severity, createdAt])
  @@index([deviceId, createdAt])
}

model AccountabilityLink {
  id                 String    @id @default(cuid())
  userId             String
  guardianUserId     String?
  guardianEmail      String
  guardianName       String?
  isActive           Boolean   @default(true)
  receivesAlerts     Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user AppUser @relation("UserAccountability", fields: [userId], references: [id], onDelete: Cascade)
  guardian AppUser? @relation("GuardianAccountability", fields: [guardianUserId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@index([guardianEmail])
}

model ProtectionPolicy {
  id                           String   @id @default(cuid())
  slug                         String   @unique
  name                         String
  description                  String?
  version                      Int      @default(1)
  isActive                     Boolean  @default(true)
  targetPornographyOnly        Boolean  @default(true)
  enforceAndroidVpn            Boolean  @default(true)
  enforceIosDnsProxy           Boolean  @default(true)
  blockUnknownDnsChanges       Boolean  @default(true)
  detectExternalVpn            Boolean  @default(true)
  detectProxy                  Boolean  @default(true)
  detectDeveloperMode          Boolean  @default(true)
  pinRequiredToDisable         Boolean  @default(true)
  heartbeatIntervalMinutes     Int      @default(15)
  staleHeartbeatGraceMinutes   Int      @default(45)
  updatedAt                    DateTime @updatedAt
  createdAt                    DateTime @default(now())

  sources BlocklistSource[]

  @@index([isActive, updatedAt])
}

model BlocklistSource {
  id                String   @id @default(cuid())
  policyId          String
  code              String
  name              String
  description       String?
  version           Int      @default(1)
  isEnabled         Boolean  @default(true)
  priority          Int      @default(0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  policy ProtectionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  entries BlocklistEntry[]

  @@unique([policyId, code])
  @@index([policyId, isEnabled, priority])
}

model BlocklistEntry {
  id          String             @id @default(cuid())
  sourceId    String
  value       String
  type        BlocklistEntryType
  note        String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  source BlocklistSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, value, type])
  @@index([sourceId, isActive])
  @@index([type, value])
}

model UnlockRequest {
  id                 String              @id @default(cuid())
  userId             String
  deviceId           String?
  actionType         UnlockActionType
  status             UnlockRequestStatus @default(PENDING)
  requestedByEmail   String
  partnerEmail       String
  approvalCodeHash   String
  reason             String?
  expiresAt          DateTime
  approvedAt         DateTime?
  cooldownEndsAt     DateTime?
  deniedAt           DateTime?
  completedAt        DateTime?
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  device ProtectedDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([deviceId, status])
  @@index([partnerEmail, status])
}
