# TCR Ingressos - variaveis de ambiente
# Copie este arquivo para .env em desenvolvimento local.
# Em producao, cadastre estes valores no painel do provedor de deploy.
# Nunca coloque chaves reais neste arquivo.

# Aplicacao
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
AUTH_SECRET="gere-um-token-longo-e-exclusivo"
CRON_SECRET="gere-outro-token-longo-para-rotinas"
HOSTING_PROVIDER="LOCAL"
HOSTING_PLAN="LOCAL"
ADMIN_HOST=""
# Exemplo em producao:
# NODE_ENV="production"
# NEXT_PUBLIC_APP_URL="https://seudominio.com.br"
# APP_URL="https://seudominio.com.br"
# HOSTING_PROVIDER="VERCEL"
# HOSTING_PLAN="VERCEL_PRO"
# ADMIN_HOST="produtor.seudominio.com.br"

# Uploads de imagens
# LOCAL funciona bem no computador e em servidor com disco persistente.
# Para deploy serverless, migrar para storage externo antes de operar vendas reais.
UPLOAD_STORAGE_PROVIDER="LOCAL"
UPLOAD_STORAGE_PERSISTENT="false"
UPLOAD_MAX_IMAGE_MB="10"
# Em servidor/VPS com disco persistente:
# UPLOAD_STORAGE_PROVIDER="LOCAL_PERSISTENT"
# UPLOAD_STORAGE_PERSISTENT="true"
# Recomendado para Vercel/producao:
# UPLOAD_STORAGE_PROVIDER="SUPABASE_STORAGE"
# SUPABASE_URL="https://PROJECT_REF.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="cole-a-service-role-key-aqui"
# SUPABASE_STORAGE_BUCKET="event-media"

# Banco de dados Supabase/Postgres
# DATABASE_URL usa pooling para a aplicacao.
# DIRECT_URL usa conexao direta para migracoes Prisma.
DATABASE_PROVIDER="SUPABASE"
DATABASE_PLAN="LOCAL"
DATABASE_URL="postgresql://postgres.PROJECT_REF:SENHA@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:SENHA@HOST.pooler.supabase.com:5432/postgres"
# Em producao recomendada:
# DATABASE_PLAN="SUPABASE_PRO"

# Usuario inicial do painel administrativo
SEED_ADMIN_NAME="Nome do administrador"
SEED_ADMIN_EMAIL="admin@seudominio.com.br"
SEED_ADMIN_PASSWORD="senha-forte-do-admin"

# Pagamentos
# Use SIMULATED apenas para desenvolvimento local.
# Para venda real no Brasil, use ASAAS.
PAYMENT_PROVIDER="ASAAS"

# Asaas
# Sandbox: https://api-sandbox.asaas.com/v3
# Producao: https://api.asaas.com/v3
ASAAS_API_URL="https://api-sandbox.asaas.com/v3"
ASAAS_API_KEY="cole-a-chave-do-asaas-aqui"
ASAAS_BILLING_TYPE="UNDEFINED"
ASAAS_WEBHOOK_TOKEN="mesmo-token-configurado-no-webhook-asaas"
# Webhook de producao no painel Asaas:
# https://seudominio.com.br/api/webhooks/payments/asaas?token=SEU_ASAAS_WEBHOOK_TOKEN

# Cron de expiracao de reservas pendentes:
# https://seudominio.com.br/api/maintenance/expire-orders?token=SEU_CRON_SECRET

# Split Asaas
ASAAS_SPLIT_ENABLED="false"
# ASAAS_SPLIT_WALLET_ID_1=""
# ASAAS_SPLIT_PERCENTUAL_VALUE_1="10"
# ASAAS_SPLIT_FIXED_VALUE_1="20.00"
# ASAAS_SPLIT_WALLET_ID_2=""
# ASAAS_SPLIT_PERCENTUAL_VALUE_2="10"
# ASAAS_SPLIT_FIXED_VALUE_2="20.00"
# ASAAS_SPLIT_WALLET_ID_3=""
# ASAAS_SPLIT_PERCENTUAL_VALUE_3="10"
# ASAAS_SPLIT_FIXED_VALUE_3="20.00"

# Mercado Pago - opcional/futuro
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""
MERCADO_PAGO_USE_SANDBOX_URL="true"

# E-mail transacional
RESEND_API_KEY=""
EMAIL_FROM="TCR Ingressos <ingressos@seudominio.com.br>"

# Login Google no checkout
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
